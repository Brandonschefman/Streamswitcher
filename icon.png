export default function StreamSwitchLogo({ size = 120 }) {
  return (
    <svg
      width={size}
      height={size}
      viewBox="0 0 120 120"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="StreamSwitch logo"
    >
      <defs>
        <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stopColor="#111827" />
          <stop offset="100%" stopColor="#020617" />
        </linearGradient>

        <linearGradient id="green" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stopColor="#34d399" />
          <stop offset="100%" stopColor="#22c55e" />
        </linearGradient>

        <filter id="glow">
          <feGaussianBlur stdDeviation="2.5" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <rect width="120" height="120" rx="28" fill="url(#bg)" />

      {/* Top green arrow */}
      <path
        d="M30 53 A32 32 0 0 1 89 44"
        fill="none"
        stroke="url(#green)"
        strokeWidth="10"
        strokeLinecap="round"
        filter="url(#glow)"
      />
      <path d="M92 43 L82 35 L82 51 Z" fill="#22c55e" />

      {/* Bottom white arrow */}
      <path
        d="M90 67 A32 32 0 0 1 31 76"
        fill="none"
        stroke="#ffffff"
        strokeWidth="10"
        strokeLinecap="round"
      />
      <path d="M28 77 L38 85 L38 69 Z" fill="#ffffff" />

      {/* Play button */}
      <path d="M51 42 L51 78 L80 60 Z" fill="#ffffff" />
    </svg>
  );
}
